command -v git-lfs >/dev/null 2>&1 && git lfs pre-push "$@"

printf "\n[pre-push] Typechecking client + server (parallel)...\n"
npm run typecheck || { printf >&2 "\n[pre-push] Typecheck failed.\n"; exit 1; }

printf "[pre-push] Building client + running server tests (parallel)...\n"
concurrently --kill-others-on-fail \
  -n build,test -c blue,green \
  "npm --prefix client run build" \
  "npm --prefix server test" \
  || { printf >&2 "\n[pre-push] Build or server tests failed.\n"; exit 1; }

printf "[pre-push] Running client tests...\n"
npm --prefix client test || { printf >&2 "\n[pre-push] Client tests failed.\n"; exit 1; }
