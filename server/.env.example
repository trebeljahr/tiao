# For local development with docker-compose, no .env file is needed.
# server/.env.development ships with working defaults for the local
# MinIO + MongoDB containers started by `npm run dev:infra`.
# Only create this .env file if you need custom/production settings.

PORT=3000
FRONTEND_URL=https://tiao.example.com
MONGODB_URI=mongodb://user:password@mongo:27017/tiao
TOKEN_SECRET=replace-me
S3_BUCKET_NAME=tiao-assets
S3_PUBLIC_URL=https://assets.example.com
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Optional for S3-compatible storage like MinIO, Cloudflare R2, or Hetzner Object Storage.
# S3_ENDPOINT=https://minio.example.com
# S3_FORCE_PATH_STYLE=true

# Backwards-compatible alias if you still use CloudFront naming.
# CLOUDFRONT_URL=https://assets.example.com

# Required: Redis for distributed matchmaking, locks, timers, broadcasts,
# and rate limiting. The server refuses to start without it outside of
# tests (NODE_ENV=test). `npm run dev` auto-starts a Redis container via
# docker-compose.dev.yml; this URL matches that container.
REDIS_URL=redis://127.0.0.1:6379

# --- OpenPanel (server-side analytics) ---------------------------------------
# Required to enable server-side tracking of authoritative events (signups,
# game finishes, payments). When any of the three is missing the server SDK
# boots disabled and all calls become no-ops — safe default for tests & CI.
# The client secret must NEVER appear in the client bundle; keep it here only.
# OPENPANEL_CLIENT_ID=
# OPENPANEL_CLIENT_SECRET=
# OPENPANEL_API_URL=
# Optional. Set to "true" to also send from NODE_ENV=development.
# OPENPANEL_ENABLE_IN_DEV=false
#
# Read-mode credentials for the Export API (used by the GDPR data export to
# include analytics events). Create a separate "read" client in the OpenPanel
# dashboard — the default "write" client doesn't have Export API access.
# When missing, data exports still work but won't include analytics events.
# OPENPANEL_READ_CLIENT_ID=
# OPENPANEL_READ_CLIENT_SECRET=
#
# Dev/prod separation: To keep dev events out of prod analytics, create a
# separate OpenPanel project for development and use its CLIENT_ID here
# (or in .env.development). Events are tagged with an `environment` global
# property, but a separate project avoids polluting dashboards entirely.

# --- GlitchTip (error monitoring) -------------------------------------------
# Sentry-compatible DSN pointing at your self-hosted GlitchTip instance.
# When unset the error reporting SDK boots disabled — safe for dev/CI/test.
# GLITCHTIP_DSN=https://key@glitchtip.trebeljahr.com/1
