{
  "name": "tiao-server",
  "version": "0.1.0",
  "engines": {
    "node": "24.14.x"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "eslint": "eslint .",
    "start": "NODE_ENV=production node dist/server/index.js",
    "dev": "NODE_ENV=development NODE_OPTIONS='--no-deprecation' nodemon --watch . --watch ../shared --ext ts --exec 'tsx' index.ts",
    "dev:e2e": "NODE_ENV=test nodemon --watch . --watch ../shared --ext ts --exec 'tsx' index.ts",
    "test": "NODE_ENV=test npm run build && NODE_ENV=test NODE_OPTIONS='--no-deprecation' node --test --test-reporter=spec dist/server/tests/*.test.js",
    "prod": "pm2 restart ecosystem.config.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@openpanel/sdk": "^1.3.0",
    "@sentry/node": "^10.48.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.6",
    "bullmq": "^5.73.5",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jimp": "^1.6.0",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.10.0",
    "stripe": "^22.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "nodemon": "^3.1.14",
    "swagger-jsdoc": "^6.2.8",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
