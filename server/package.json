{
  "name": "tiao-server",
  "version": "0.1.0",
  "engines": {
    "node": "22.20.x"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "eslint": "eslint .",
    "start": "NODE_ENV=production node dist/server/index.js",
    "dev": "NODE_ENV=development nodemon --watch . --watch ../shared --ext ts index.ts",
    "dev:e2e": "NODE_ENV=test nodemon --watch . --watch ../shared --ext ts index.ts",
    "test": "NODE_ENV=test npm run build && NODE_ENV=test node --test dist/server/tests/*.test.js",
    "prod": "pm2 restart ecosystem.config.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.670.0",
    "bcrypt": "^5.1.1",
    "better-auth": "^1.5.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jimp": "^1.6.0",
    "mongoose": "^8.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "rate-limit-redis": "^4.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "express": "^4.21.0",
    "nodemon": "^3.1.6",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.57.2"
  }
}
