{
  "name": "tiao-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron wrapper for the Tiao desktop app — Phase 3a standalone build.",
  "main": "main.cjs",
  "engines": {
    "node": "24.14.x"
  },
  "scripts": {
    "dev": "npm run dev:ensure-bundle && electron .",
    "dev:prod": "NEXT_PUBLIC_DESKTOP_API_URL=https://api.playtiao.com npm run dev:rebuild-client && electron .",
    "dev:ensure-bundle": "test -f client-bundle/en/index.html || npm run dev:build-client",
    "dev:build-client": "NEXT_PUBLIC_DESKTOP_API_URL=${NEXT_PUBLIC_DESKTOP_API_URL:-http://localhost:5005} npm --prefix ../client run build:desktop && rm -rf client-bundle && cp -R ../client/.next-desktop/. client-bundle",
    "dev:rebuild-client": "npm run dev:build-client",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder",
    "package:all": "electron-builder -mwl",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "site.playtiao.desktop",
    "productName": "Tiao",
    "copyright": "Copyright © 2026 Tiao contributors",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "src/**/*.cjs",
      "package.json",
      "!node_modules/.cache/**",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "client-bundle",
        "to": "client-bundle",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.board-games",
      "icon": "assets/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "icon": "assets/icon.png",
      "synopsis": "A beautiful abstract strategy board game.",
      "description": "Play Tiao online or offline — local 2-player, AI opponent, tutorial, and multiplayer when connected."
    },
    "protocols": [
      {
        "name": "Tiao",
        "schemes": [
          "tiao"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "trebeljahr",
      "repo": "tiao",
      "releaseType": "draft"
    }
  }
}
